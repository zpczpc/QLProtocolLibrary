<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>QLProtocolLibrary</PackageId>
    <Version>0.4.0</Version>
    <Authors>zpczpc</Authors>
    <Company>zpczpc</Company>
    <Description>Packet builder and parser library for QL device communication based on device address, function code, payload, and CRC16. Suitable for serial, RS485, and transparent transport scenarios, with both high-level known-register APIs and generic typed packet APIs.</Description>
    <PackageTags>protocol;serial;rs485;packet;crc16;parser;industrial;water-quality</PackageTags>
    <PackageProjectUrl>https://github.com/zpczpc/QLProtocolLibrary</PackageProjectUrl>
    <RepositoryUrl>https://github.com/zpczpc/QLProtocolLibrary</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <RepositoryBranch>main</RepositoryBranch>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>See CHANGELOG.md in the GitHub repository for version details. Version 0.4.0 aligns the core packet model with the main application-layer structure based on device address, function code, payload, and CRC16, and updates the public docs and demos accordingly.</PackageReleaseNotes>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="README.en.md" Pack="true" PackagePath="\" />
    <None Include="icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

